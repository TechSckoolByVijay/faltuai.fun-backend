# Environment Variables Configuration
# Copy this file to .env and update with your actual values

# ================================
# GOOGLE OAUTH CONFIGURATION
# ================================
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google+ API
# 4. Go to Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Set authorized redirect URI: http://localhost:8000/auth/google/callback

GOOGLE_CLIENT_ID=dummy-google-id
GOOGLE_CLIENT_SECRET=dummy-google-secret

# ================================
# APPLICATION URLS
# ================================
# Frontend URL (where your React app runs)
FRONTEND_URL=http://localhost:5173

# Backend URL (where your FastAPI runs) - used by frontend
VITE_BACKEND_URL=http://localhost:8000

# ================================
# JWT CONFIGURATION
# ================================
# Use a strong, random secret key for JWT signing in production
# Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=dummysecret

# ================================
# APPLICATION SETTINGS
# ================================
# Set to false in production
DEBUG=true

# ================================
# DATABASE CONFIGURATION (Optional)
# ================================
# Uncomment and configure when adding database support
# DATABASE_URL=postgresql://username:password@localhost:5432/faltuai_db

# ================================
# OPENAI CONFIGURATION
# ================================
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=dummy-openai-key
OPENAI_MODEL=gpt-3.5-turbo

# ================================
# LANGCHAIN & LANGSMITH CONFIGURATION
# ================================
# LangSmith for monitoring and tracing AI operations
# Get API key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=dummy-langsmith-key
LANGCHAIN_PROJECT=faltuai-fun
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ================================
# DATABASE CONFIGURATION
# ================================
# PostgreSQL configuration for Docker
POSTGRES_DB=faltuai_db
POSTGRES_USER=faltuai_user
POSTGRES_PASSWORD=faltuai_password
DATABASE_URL=postgresql://faltuai_user:faltuai_password@postgres:5432/faltuai_db
ASYNC_DATABASE_URL=postgresql+asyncpg://faltuai_user:faltuai_password@postgres:5432/faltuai_db

# ================================
# AZURE DOCUMENT INTELLIGENCE (Optional)
# ================================
# Get these from Azure Portal - Document Intelligence resource
AZURE_DOC_INTELLIGENCE_ENDPOINT=dummy-endpoint
AZURE_DOC_INTELLIGENCE_KEY=dummy-key

# ================================
# PRODUCTION SETTINGS
# ================================
# For production deployment, update these:
# FRONTEND_URL=https://your-domain.com
# VITE_BACKEND_URL=https://api.your-domain.com
# DEBUG=false
# JWT_SECRET_KEY=your-super-secure-secret-key

# ================================
# DOCKER SETTINGS
# ================================
# These are used by docker-compose.yml
# Usually you don't need to change these for local development
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ================================
# SETUP INSTRUCTIONS
# ================================
# 1. Copy this file: cp .env.example .env
# 2. Update GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET with real values
# 3. Generate a secure JWT_SECRET_KEY for production
# 4. Update URLs for your production environment
# 5. Run: docker-compose up --build